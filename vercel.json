{
  "buildCommand": "vite build",
  "devCommand": "vite --port $PORT",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/v2", "destination": "/landing-v2.html" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!landing|sample|favicon|api).*)", "destination": "/" }
  ]
}
